NODE_ENV=development
PORT=5010
WORKER_PORT=5001
API_BASE_URL=http://localhost:5010
FRONTEND_URL=http://localhost:5180

DB_HOST=localhost
DB_PORT=3306
DB_NAME=job_scheduler
DB_USER=jobscheduler
DB_PASSWORD=jobscheduler_password
DB_DIALECT=mysql
DB_POOL_MAX=20
DB_POOL_MIN=2
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

JWT_ACCESS_SECRET=replace_with_a_long_random_access_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_a_long_random_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d

BCRYPT_ROUNDS=12
WORKER_HEARTBEAT_TIMEOUT_SECONDS=60
LOG_LEVEL=info
